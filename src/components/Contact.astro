---
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">

      <div class="contact-info">
        <p class="section-label">Get in touch</p>
        <h2 class="section-title">Let's work<br /><span class="title-accent">together</span></h2>
        <p class="contact-bio">
          I'm open to new opportunities, collaborations, and interesting projects.
          Whether you have a question or just want to say hello — my inbox is always open.
        </p>

        <div class="contact-links">
          <a href="mailto:andres.rov.m.s@gmail.com" class="contact-link-item">
            <div class="link-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="link-text">
              <span class="link-label">Email</span>
              <span class="link-value">andres.rov.m.s@gmail.com</span>
            </div>
          </a>

          <a href="https://github.com/Rov95" target="_blank" rel="noopener noreferrer" class="contact-link-item">
            <div class="link-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </div>
            <div class="link-text">
              <span class="link-label">GitHub</span>
              <span class="link-value">github.com/Rov95</span>
            </div>
          </a>

          <a href="https://linkedin.com/in/andres-menco-5947922bb" target="_blank" rel="noopener noreferrer" class="contact-link-item">
            <div class="link-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </div>
            <div class="link-text">
              <span class="link-label">LinkedIn</span>
              <span class="link-value">andres-menco</span>
            </div>
          </a>
        </div>
      </div>

      <div class="contact-form-wrap">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label for="name" class="form-label">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="form-input"
                placeholder="Your name"
                autocomplete="name"
                required
              />
            </div>
            <div class="form-field">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="your@email.com"
                autocomplete="email"
                required
              />
            </div>
          </div>

          <div class="form-field">
            <label for="message" class="form-label">Message</label>
            <textarea
              id="message"
              name="message"
              class="form-input form-textarea"
              placeholder="Tell me about your project..."
              rows="6"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn-submit" id="submit-btn">
            <span class="btn-label">Send message</span>
            <span class="btn-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </span>
          </button>

          <p class="form-status" id="form-status" aria-live="polite"></p>
        </form>
      </div>

    </div>
  </div>

  <div class="contact-bg-accent"></div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('form-status') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const name = (formData.get('name') as string).trim();
    const email = (formData.get('email') as string).trim();
    const message = (formData.get('message') as string).trim();

    if (!name || !email || !message) {
      statusEl.textContent = 'Please fill in all fields.';
      statusEl.className = 'form-status error';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    // Simulate sending (replace with your actual endpoint)
    await new Promise(resolve => setTimeout(resolve, 1200));

    submitBtn.disabled = false;
    submitBtn.classList.remove('loading');
    form.reset();

    statusEl.textContent = 'Message sent! I\'ll get back to you soon.';
    statusEl.className = 'form-status success';

    setTimeout(() => {
      statusEl.textContent = '';
      statusEl.className = 'form-status';
    }, 5000);
  });
</script>

<style>
  .contact {
    padding: 8rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .contact-bg-accent {
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(192, 57, 43, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-bio {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .title-accent {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--text-primary);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-link-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: opacity 0.2s;
  }

  .contact-link-item:hover {
    opacity: 0.8;
  }

  .link-icon {
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: border-color 0.2s, color 0.2s;
    background: var(--bg-card);
  }

  .contact-link-item:hover .link-icon {
    border-color: var(--border-accent);
    color: var(--accent-red-bright);
  }

  .link-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .link-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .link-value {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  /* Form */
  .contact-form-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2.5rem;
    position: relative;
  }

  .contact-form-wrap::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-red), transparent);
    border-radius: 6px 6px 0 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .form-input {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--text-primary);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: none;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-input:focus {
    border-color: rgba(192, 57, 43, 0.5);
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.08);
  }

  .form-textarea {
    line-height: 1.7;
    min-height: 140px;
  }

  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--accent-red);
    color: #fff;
    border: 1px solid var(--accent-red);
    border-radius: 3px;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, transform 0.2s;
    width: 100%;
  }

  .btn-submit:hover:not(:disabled) {
    background: var(--accent-red-bright);
    transform: translateY(-1px);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-submit.loading .btn-label::after {
    content: '...';
  }

  .btn-submit.loading .btn-icon {
    display: none;
  }

  .form-status {
    font-size: 0.8rem;
    text-align: center;
    min-height: 1.2em;
    transition: color 0.2s;
  }

  .form-status.success { color: #4ade80; }
  .form-status.error   { color: var(--accent-red-bright); }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrap {
      padding: 1.75rem;
    }
  }
</style>
