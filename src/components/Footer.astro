---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {year} Andres Menco. All rights reserved.
    </p>
    <div class="footer-links">
      <a href="https://github.com/Rov95" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/in/andres-menco-5947922bb" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:andres.rov.m.s@gmail.com">Email</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent-red-bright);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
